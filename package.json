{
  "name": "animind-desktop-player",
  "version": "0.2.0",
  "private": true,
  "description": "Animind native desktop player (Qt/QML + libmpv)",
  "author": "Animind",
  "scripts": {
    "configure": "cmake -S qt_host -B qt_host/build -DCMAKE_PREFIX_PATH=\"%CD%/qt_host/.qt/6.5.3/msvc2019_64\" -A x64",
    "build": "cmake --build qt_host/build --config Release",
    "dev": "npm run build && npm run start",
    "start": "qt_host\\build\\Release\\AnimindQtHost.exe",
    "install:qt": "python -m aqt install-qt windows desktop 6.5.3 win64_msvc2019_64 -O qt_host/.qt",
    "clean:build": "Remove-Item -Recurse -Force qt_host/build -ErrorAction SilentlyContinue",
    "test": "jest"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/qt_host/tests/**/*.test.js"
    ],
    "transform": {}
  },
  "devDependencies": {
    "fast-check": "^4.8.0",
    "jest": "^29.7.0"
  }
}
