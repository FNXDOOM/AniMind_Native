{
  "name": "animind-desktop-player",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Animind native desktop player",
  "main": "dist/main/index.js",
  "author": "Animind",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "native:install": "npm install --prefix native",
    "native:build": "npm run build --prefix native",
    "native:rebuild": "node scripts/rebuild-native.cjs",
    "typecheck": "tsc --noEmit",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.animind.desktop",
    "productName": "Animind Desktop",
    "directories": {
      "output": "release"
    },
    "protocols": {
      "name": "Animind Deep Link",
      "schemes": [
        "animind"
      ]
    },
    "files": [
      "dist/**/*",
      "package.json",
      "native/build/Release/**",
      "vendor/mpv/win-x64/**"
    ],
    "extraMetadata": {
      "main": "dist/main/index.js"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
